{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "paths": {
      "@vuerend/core": ["../core/src/index.ts"],
      "@vuerend/core/*": ["../core/src/*"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src", "vite.config.ts"]
}
